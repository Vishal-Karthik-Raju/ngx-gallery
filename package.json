{
  "name": "@vishal/ngx-gallery",
  "version": "21.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build-prod": "ng build --configuration production",
    "test": "ng test",
    "lint:lib": "ng lint @vishal/ngx-gallery",
    "e2e": "ng e2e",
    "build-watch:lib": "ng build @vishal/ngx-gallery --watch",
    "test:lib": "ng test @vishal/ngx-gallery",
    "build:lib": "ng build --configuration production @vishal/ngx-gallery",
    "publish:lib": "npm run copy:readme && npm run copy:changelog && npm run copy:license && npm publish ./dist/gallery",
    "copy:readme": "cpx README.md dist/gallery",
    "copy:changelog": "cpx CHANGELOG.md dist/gallery",
    "copy:license": "cpx LICENSE dist/gallery",
    "test-ci": "ng test @vishal/ngx-gallery --code-coverage --no-watch --no-progress --browsers=ChromeHeadless"
  },
  "private": false,
  "dependencies": {
    "@angular/animations": "21.0.0",
    "@angular/common": "21.0.0",
    "@angular/compiler": "21.0.0",
    "@angular/core": "21.0.0",
    "@angular/forms": "21.0.0",
    "@angular/platform-browser": "21.0.0",
    "@angular/platform-browser-dynamic": "21.0.0",
    "@angular/router": "21.0.0",
    "font-awesome": "^4.7.0",
    "hammerjs": "^2.0.8",
    "karma-viewport": "^1.0.8",
    "rxjs": "^6.5.4",
    "tslib": "^2.3.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.0.0",
    "@angular-eslint/builder": "^18.0.0",
    "@angular-eslint/eslint-plugin": "^18.0.0",
    "@angular-eslint/eslint-plugin-template": "^18.0.0",
    "@angular-eslint/schematics": "^18.0.0",
    "@angular-eslint/template-parser": "^18.0.0",
    "@angular/cli": "21.0.0",
    "@angular/compiler-cli": "21.0.0",
    "@angular/language-service": "21.0.0",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "coveralls": "^3.1.1",
    "cpx": "^1.5.0",
    "eslint": "^8.56.0",
    "jasmine-core": "~5.1.0",
    "jasmine-spec-reporter": "~7.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~4.0.1",
    "karma-jasmine-html-reporter": "^1.7.0",
    "ng-packagr": "21.0.0",
    "protractor": "~7.0.0",
